{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/enquire/layout,_N_T_/enquire/page,_N_T_/enquire"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/enquire/__PAGE__",
    "/enquire",
    "/_index",
    "/_head"
  ]
}