a:["$","section",null,{"className":"px-4 py-14 sm:px-6 sm:py-16 lg:px-8 lg:py-20","children":["$","div",null,{"className":"mx-auto max-w-5xl","children":["$","$L14",null,{"badge":"FAQs","items":[{"id":"benefits","title":"What are the benefits of working for Naptec?","content":["$","div",null,{"className":"space-y-4 text-base leading-relaxed text-neutral-600","children":[["$","p",null,{"children":"Our motto is personal, relationship-led care — and we live up to this every day in how we treat our clients and our Care Professionals. We match Care Professionals to clients based on personalities, interests and hobbies, with continuity so you can build meaningful relationships."}],["$","p",null,{"children":"All visits are a minimum of one hour long, so there is plenty of time to provide high quality care. When you join Naptec you have the best of both worlds — a community-based business backed by years of expertise in exceptional home care."}],["$","$L2",null,{"href":"/enquire","className":"text-sm font-medium text-[#3B2A8F] underline underline-offset-4 transition-colors hover:text-[#2d1f6d]","children":"Discover more"}]]}]},{"id":"experience","title":"Do I need previous experience within the care sector?","content":["$","div",null,{"className":"space-y-4 text-base leading-relaxed text-neutral-600","children":[["$","p",null,{"children":"Whether you are new to care entirely or have never provided it in a professional capacity, we welcome people from all backgrounds for their values, enthusiasm and empathy. Care experience is useful but not always necessary — we provide full training so all our Care Professionals can deliver care confidently and competently."}],["$","$L2",null,{"href":"/enquire","className":"text-sm font-medium text-[#3B2A8F] underline underline-offset-4 transition-colors hover:text-[#2d1f6d]","children":"Discover more"}]]}]},{"id":"training","title":"What training does Naptec provide?","content":["$","div",null,{"className":"space-y-4 text-base leading-relaxed text-neutral-600","children":[["$","p",null,{"children":"Our Care Professionals receive industry-leading training to give them the confidence, knowledge and skills to care for our clients — from basic moving and handling through to specialist dementia and end of life care."}],["$","p",null,{"children":"We support opportunities to gain recognised qualifications such as Level 2 and 3 in Health and Social Care. As a Care Professional at Naptec you will be supported through bespoke training and ongoing education."}],["$","$L2",null,{"href":"/enquire","className":"text-sm font-medium text-[#3B2A8F] underline underline-offset-4 transition-colors hover:text-[#2d1f6d]","children":"Discover more"}]]}]},{"id":"services","title":"What types of home care services does Naptec offer?","content":["$","div",null,{"className":"space-y-4 text-base leading-relaxed text-neutral-600","children":[["$","p",null,{"children":"We support clients with all aspects of day-to-day living so they can flourish and remain independent at home — from personal care and home help to companionship, transport to appointments, and overnight or live-in care."}],["$","$L2",null,{"href":"/what-we-do/domiciliary-care","className":"text-sm font-medium text-[#3B2A8F] underline underline-offset-4 transition-colors hover:text-[#2d1f6d]","children":"Discover more"}]]}]}]}]}]}]
