6:["$","div","Waking Night Service",{"className":"mx-auto mt-14 grid max-w-6xl gap-8 sm:mt-16 lg:mt-20 lg:grid-cols-2 lg:items-center lg:gap-12","children":[["$","div",null,{"className":"","children":[["$","h2",null,{"className":"text-3xl font-normal leading-tight text-neutral-900 sm:text-4xl","style":"$0:rsc:props:children:0:props:children:0:props:children:0:props:children:1:props:style","children":"Waking Night Service"}],["$","div",null,{"className":"mt-5 space-y-4 text-base leading-relaxed text-neutral-600","children":[[["$","p","0",{"children":"A waking night service is when the caregiver is awake and on duty throughout the night at your home. This service is ideal for those who wake frequently throughout the night needing care and support, such as assistance to the bathroom, personal or continence care, regular repositioning especially after an accident or injury, medication administration, or help orientating to the time of day in order to return to sleep."}],["$","p","1",{"children":"Our care is always personalised to your needs, meaning we can revisit your overnight care options whenever you require, or if there is a change in circumstances. Whatever your situation, our caregivers are on hand to ensure you live well at home, your way."}]],null,null,["$","p",null,{"className":"pt-2","children":["$","$L2",null,{"href":"/enquire","className":"text-sm font-medium text-[#3B2A8F] underline underline-offset-4","children":"Discover more"}]}]]}]]}],["$","div",null,{"className":"relative aspect-[4/3] w-full overflow-hidden rounded-sm bg-[#f2f2f2] ","children":["$","$L3",null,{"src":"https://res.cloudinary.com/dw1n6qugv/image/upload/v1778933382/pexels-jsme-mila-523821574-18459193_nlhoas.jpg","alt":"Waking night care service","fill":true,"sizes":"(max-width: 1024px) 100vw, 50vw","className":"object-cover"}]}]]}]
