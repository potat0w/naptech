4:["$","div","Benefits of respite care",{"className":"mx-auto mt-14 grid max-w-6xl gap-8 sm:mt-16 lg:mt-20 lg:grid-cols-2 lg:items-center lg:gap-12","children":[["$","div",null,{"className":"lg:order-2","children":[["$","h2",null,{"className":"text-3xl font-normal leading-tight text-neutral-900 sm:text-4xl","style":"$0:rsc:props:children:0:props:children:0:props:children:0:props:children:1:props:style","children":"Benefits of respite care"}],["$","div",null,{"className":"mt-5 space-y-4 text-base leading-relaxed text-neutral-600","children":[[["$","p","0",{"children":"By choosing our tailored respite care services, you will have peace of mind knowing that essential care is being taken care of whilst you recharge your batteries. Respite care can take different forms, from a short break to a longer-term stay that enables you to enjoy a holiday."}],["$","p","1",{"children":"We can also provide home visits to support you to care for your loved one if you need time to get back on your feet – for example after a hospital stay or if you have been unwell."}],["$","p","2",{"children":"Our caregivers are highly trained and experienced in providing a variety of care services including companionship, personal care and dementia care."}]],null,["$","p",null,{"className":"pt-2","children":["$","$L2",null,{"href":"/enquire","className":"inline-flex min-h-12 items-center justify-center rounded-full bg-brand px-7 py-3 text-sm font-semibold text-white shadow-[0_8px_28px_-8px_rgba(100,69,150,0.4)] transition-all duration-200 hover:bg-brand-dark hover:shadow-[0_10px_32px_-8px_rgba(100,69,150,0.5)]","children":"Enquire now"}]}],null]}]]}],["$","div",null,{"className":"relative aspect-[4/3] w-full overflow-hidden rounded-sm bg-[#f2f2f2] lg:order-1","children":["$","$Lc",null,{"src":"https://res.cloudinary.com/dw1n6qugv/image/upload/v1778933350/pexels-jsme-mila-523821574-29372720_niar1j.jpg","alt":"Family carer taking a well-deserved break","fill":true,"sizes":"(max-width: 1024px) 100vw, 50vw","className":"object-cover"}]}]]}]
5:["$","section",null,{"className":"border-y border-neutral-100 bg-[#faf8f4] px-4 py-14 sm:px-6 sm:py-16 lg:px-8","children":["$","div",null,{"className":"mx-auto grid max-w-6xl gap-10 lg:grid-cols-2 lg:gap-16","children":[["$","div",null,{"children":[["$","h2",null,{"className":"text-3xl font-normal text-neutral-900 sm:text-4xl","style":"$0:rsc:props:children:0:props:children:0:props:children:0:props:children:1:props:style","children":["How can we ",["$","em",null,{"className":"italic","children":"help?"}]]}],["$","p",null,{"className":"mt-4 text-base leading-relaxed text-neutral-600","children":"We have helped thousands of families to stay safe, comfortable and happy at home. Whatever situation you are facing, Naptec is here to help."}],["$","p",null,{"className":"mt-6 text-sm text-neutral-600","children":"Are you in need of a little guidance right away?"}],["$","$L2",null,{"href":"/enquire","className":"mt-6 inline-block text-sm text-neutral-600 underline underline-offset-4 transition-colors hover:text-[#3B2A8F]","children":"Other non-care-related enquiries"}]]}],["$","div",null,{"className":"flex flex-col justify-center","children":["$","$L2",null,{"href":"/enquire","className":"w-fit inline-flex min-h-12 items-center justify-center rounded-full bg-brand px-7 py-3 text-sm font-semibold text-white shadow-[0_8px_28px_-8px_rgba(100,69,150,0.4)] transition-all duration-200 hover:bg-brand-dark hover:shadow-[0_10px_32px_-8px_rgba(100,69,150,0.5)]","children":"Enquire now"}]}]]}]}]
