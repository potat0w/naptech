c:["$","section",null,{"className":"px-4 pb-10 sm:px-6 sm:pb-14 lg:px-8 lg:pb-16","children":[["$","div",null,{"className":"mx-auto mt-14 grid max-w-6xl gap-8 sm:mt-16 lg:mt-20 lg:grid-cols-2 lg:items-center lg:gap-12","children":[["$","div",null,{"className":"lg:order-2","children":[["$","h2",null,{"className":"text-3xl font-normal leading-tight text-neutral-900 sm:text-4xl","style":"$0:f:0:1:1:children:1:children:1:children:0:props:children:0:props:children:0:props:children:0:props:children:2:props:style","children":"What does home care involve?"}],["$","div",null,{"className":"mt-5 space-y-4 text-base leading-relaxed text-neutral-600","children":[["$","p",null,{"children":"Home care (sometimes called domiciliary care) means care received in someone's own home instead of in a hospital, clinic, care home or elsewhere. This could mean help with daily activities like cooking or getting dressed, or more intensive medical support. Whatever you require, if you are not yet ready to move to a care home, your needs can likely be met in the comfort of your own home by a trained professional."}],["$","p",null,{"className":"pt-2","children":["$","$L7",null,{"href":"/what-we-do/domiciliary-care","className":"text-sm font-medium text-[#3B2A8F] underline underline-offset-4 transition-colors hover:text-[#2d1f6d]","children":"Read our guide to what home or domiciliary care is"}]}]]}]]}],["$","div",null,{"className":"relative aspect-[4/3] w-full overflow-hidden rounded-sm bg-[#f2f2f2] lg:order-1","children":["$","$L14",null,{"src":"https://res.cloudinary.com/dw1n6qugv/image/upload/v1778932857/centre-for-ageing-better-rQJ3xo-0WYE-unsplash_mhe64i.jpg","alt":"Caregiver helping with daily activities at home","fill":true,"sizes":"(max-width: 1024px) 100vw, 50vw","className":"object-cover"}]}]]}],["$","div",null,{"className":"mx-auto mt-14 grid max-w-6xl gap-8 sm:mt-16 lg:mt-20 lg:grid-cols-2 lg:items-center lg:gap-12","children":[["$","div",null,{"className":"","children":[["$","h2",null,{"className":"text-3xl font-normal leading-tight text-neutral-900 sm:text-4xl","style":"$0:f:0:1:1:children:1:children:1:children:0:props:children:0:props:children:0:props:children:0:props:children:2:props:style","children":"Is home care more affordable than a care home?"}],["$","div",null,{"className":"mt-5 space-y-4 text-base leading-relaxed text-neutral-600","children":[[["$","p",null,{"children":"Data from the National Audit Office suggests that the projected increase in adults aged 65+ requiring care by 2038 is 57% (compared with 2018), and the projected increase in the cost of that care for the same demographic is 106%. Not only is demand for care homes set to increase, but the price of care will increase too. Home care can provide a more affordable alternative to a care home that allows you to pay only for the care you need."}],["$","p",null,{"children":"Since the government actively aims to keep older people living at home for as long as possible, there are many support options in place if you are interested in choosing home care over moving to a care home."}]],["$","p",null,{"className":"pt-2","children":["$","$L7",null,{"href":"/advice-and-care/articles","className":"text-sm font-medium text-[#3B2A8F] underline underline-offset-4 transition-colors hover:text-[#2d1f6d]","children":"Read our guide to the benefits of home care versus a care home"}]}]]}]]}],["$","div",null,{"className":"relative aspect-[4/3] w-full overflow-hidden rounded-sm bg-[#f2f2f2] ","children":["$","$L14",null,{"src":"https://res.cloudinary.com/dw1n6qugv/image/upload/v1778933400/pexels-kampus-8949833_tldckz.jpg","alt":"Older adult receiving care at home","fill":true,"sizes":"(max-width: 1024px) 100vw, 50vw","className":"object-cover"}]}]]}],["$","div",null,{"className":"mx-auto mt-14 max-w-6xl sm:mt-16 lg:mt-20","children":[["$","h2",null,{"className":"text-3xl font-normal leading-tight text-neutral-900 sm:text-4xl","style":"$0:f:0:1:1:children:1:children:1:children:0:props:children:0