8:["$","div",null,{"className":"mx-auto mt-14 grid max-w-6xl gap-8 sm:mt-16 lg:mt-20 lg:grid-cols-2 lg:items-center lg:gap-12","children":[["$","div",null,{"className":"","children":[["$","h2",null,{"className":"text-3xl font-normal leading-tight text-neutral-900 sm:text-4xl","style":"$0:f:0:1:1:children:1:children:1:children:0:props:children:0:props:children:0:props:children:0:props:children:1:props:style","children":"At Naptec, we're here to help you age well"}],["$","div",null,{"className":"mt-5 space-y-4 text-base leading-relaxed text-neutral-600","children":[[["$","p",null,{"children":"Growing old can be difficult, both for the person who is ageing and their family. It can be frustrating because they cannot do everything they used to and may feel as if they are losing their independence. There is only so much that loved ones can do to help."}],["$","p",null,{"children":"At Naptec, we help people age well by making it possible for them to stay at home whilst receiving high-quality, dignified care, whatever their needs are. Learn more about how we can help with care costs and funding."}]],["$","p",null,{"className":"pt-2","children":["$","$L7",null,{"href":"/advice-and-care/cost-of-care","className":"text-sm font-medium text-[#3B2A8F] underline underline-offset-4 transition-colors hover:text-[#2d1f6d]","children":"Learn more"}]}]]}]]}],["$","div",null,{"className":"relative aspect-[4/3] w-full overflow-hidden rounded-sm bg-[#f2f2f2] ","children":["$","$L14",null,{"src":"https://res.cloudinary.com/dw1n6qugv/image/upload/v1778932857/centre-for-ageing-better-rQJ3xo-0WYE-unsplash_mhe64i.jpg","alt":"Older adults enjoying time together at home","fill":true,"sizes":"(max-width: 1024px) 100vw, 50vw","className":"object-cover"}]}]]}]
9:["$","div",null,{"className":"mx-auto mt-14 grid max-w-6xl gap-8 sm:mt-16 lg:mt-20 lg:grid-cols-2 lg:items-center lg:gap-12","children":[["$","div",null,{"className":"lg:order-2","children":[["$","h2",null,{"className":"text-3xl font-normal leading-tight text-neutral-900 sm:text-4xl","style":"$0:f:0:1:1:children:1:children:1:children:0:props:children:0:props:children:0:props:children:0:props:children:1:props:style","children":"How do people react to ageing?"}],["$","div",null,{"className":"mt-5 space-y-4 text-base leading-relaxed text-neutral-600","children":[[["$","p",null,{"children":"There is no simple answer. As a parent becomes older, you might spot some changes in their behaviour. Perhaps they start to forget appointments, eat or drink less often, take more time to walk to the supermarket, or their eyesight might deteriorate. These are often early signs that it is time to get some support."}],["$","p",null,{"children":"Having this conversation is not always easy. Your loved one might see this as the first step to losing their independence. But talking about care sooner rather than later makes it a more natural process that they can be in full control of."}],["$","p",null,{"children":["Worried your loved one is forgetting things too often? Take a look at our guide on how to spot the early signs of dementia in our"," ",["$","$L7",null,{"href":"/advice-and-care/articles","className":"font-medium text-[#3B2A8F] underline underline-offset-4","children":"articles"}],"."]}]],["$","p",null,{"className":"pt-2","children":["$","$L7",null,{"href":"/enquire","className":"text-sm font-medium text-[#3B2A8F] underline underline-offset-4 transition-colors hover:text-[#2d1f6d]","children":"Discover how we can help you"}]}]]}]]}],["$","div",null,{"className":"relative aspect-[4/3] w-full overflow-hidden rounded-sm bg-[#f2f2f2] lg:order-1","children":["$","$L14",null,{"src":"https://res.cloudinary.com/dw1n6qugv/image/upload/v1778933400/pexels-kampus-8949833_tldckz.jpg","alt":"Family conversation about ageing and care","fill":true,"sizes":"(max-width: 1024px) 100vw, 50vw","className":"object-cover"}]}]]}]
a:["$","div",null,{"className":"mx-auto mt-14 grid max-w-6xl gap-8 sm:mt-16 lg:mt-20 lg:grid-cols-2 lg:items-center lg:gap-12","children":[["$","div",null,{"className":"","children":[["$","h2",null,{"className":"text-3xl font-normal leading-tight text-neutral-900 sm:text-4xl","style":"$0:f:0:1:1:children:1:children:1:children:0:props:children:0:props:children:0:props:children:0:props:children:1:props:style","children":"Can home care slow ageing?"}],["$","div",null,{"className":"mt-5 space-y-4 text-base leading-relaxed text-neutral-600","children":[[["$","p",null,{"children":"Home care has all sorts of benefits, not least the chance to stay in familiar surroundings. Often, homes are bursting with happy memories, so it can be heartbreaking and incredibly disruptive to move out, especially for people living with dementia. Residential care does not have to be the answer for anyone struggling with day-to-day tasks."}],["$","p",null,{"children":"Your older loved one could benefit hugely from somebody making care visits to their home and giving support when needed. Over the years we have found that caring for somebody at home early on can prevent accidents and even delay the need to move out. Our caregivers build a strong relationship with the person they visit, helping them spot any changes in health or behaviour and taking the necessary actions to prevent the situation from worsening."}]],null]}]]}],["$","div",null,{"className":"relative aspect-[4/3] w-full overflow-hidden rounded-sm bg-[#f2f2f2] ","children":["$","$L14",null,{"src":"https://res.cloudinary.com/dw1n6qugv/image/upload/v1778933400/pexels-olly-3768131_mdki5q.jpg","alt":"Caregiver supporting an older adult at home","fill":true,"sizes":"(max-width: 1024px) 100vw, 50vw","className":"object-cover"}]}]]}]
b:["$","div",null,{"className":"mx-auto mt-16 max-w-6xl sm:mt-20","children":["$","div",null,{"className":"grid gap-6 sm:grid-cols-2","children":[["$","article","Health & Wellbeing",{"className":"rounded-2xl bg-[#f4f4f4] p-8","children":[["$","h3",null,{"className":"text-2xl font-normal text-neutral-900","style":"$0:f:0:1:1:children:1:children:1:children:0:props:children:0:props:children:0:props:children:0:props:children:1:props:style","children":"Health & Wellbeing"}],["$","p",null,{"className":"mt-4 text-sm leading-relaxed text-neutral-600","children":"We all need to take care of our health and wellbeing no matter our age. We provide tips on different ways to exercise or keep your mind active."}],["$","$L7",null,{"href":"/advice-and-care/articles","className":"mt-5 inline-block text-sm font-medium text-[#3B2A8F] underline underline-offset-4 transition-colors hover:text-[#2d1f6d]","children":"Discover more"}]]}],["$","article","Nutrition",{"className":"rounded-2xl bg-[#f4f4f4] p-8","children":[["$","h3",null,{"className":"text-2xl font-normal text-neutral-900","style":"$0:f:0:1:1:children:1:children:1:children:0:props:children:0:props:children:0:props:children:0:props:children:1:props:style","children":"Nutrition"}],["$","p",null,{"className":"mt-4 text-sm leading-relaxed text-neutral-600","children":"We aim to raise awareness of the importance of maintaining healthy eating habits and reducing the risk of malnutrition to keep older people healthy at home."}],["$","$L7",null,{"href":"/advice-and-care/articles","className":"mt-5 inline-block text-sm font-medium text-[#3B2A8F] underline underline-offset-4 transition-colors hover:text-[#2d1f6d]","children":"Discover more"}]]}],["$","article","Mental Health",{"className":"rounded-2xl bg-[#f4f4f4] p-8","children":[["$","h3",null,{"className":"text-2xl font-normal text-neutral-900","style":"$0:f:0:1:1:children:1:children:1:children:0:props:children:0:props:children:0:props:children:0:props:children:1:props:style","children":"Mental Health"}],["$","p",null,{"className":"mt-4 text-sm leading-relaxed text-neutral-600","children":"Getting older does not necessarily mean your mental abilities will be impacted. Keeping an active mind can help keep you physically and mentally well at home."}],["$","$L7",null,{"href":"/advice-and-care/articles","className":"mt-5 inline-block text-sm font-medium text-[#3B2A8F] underline underline-offset-4 transition-colors hover:text-[#2d1f6d]","children":"Discover more"}]]}],["$","article","Frailty",{"className":"rounded-2xl bg-[#f4f4f4] p-8","children":[["$","h3",null,{"className":"text-2xl font-normal text-neutral-900","style":"$0:f:0:1:1:children:1:children:1:children:0:props:children:0:props:children:0:props:children:0:props:children:1:props:style","children":"Frailty"}],["$","p",null,{"className":"mt-4 text-sm leading-relaxed text-neutral-600","children":"Frailty is a common condition in which older people become less able to recover from difficulties during everyday life. We offer advice on recovery and fall prevention."}],["$","$L7",null,{"href":"/advice-and-care/articles","className":"mt-5 inline-block text-sm font-medium text-[#3B2A8F] underline underline-offset-4 transition-colors hover:text-[#2d1f6d]","children":"Discover more"}]]}]]}]}]
