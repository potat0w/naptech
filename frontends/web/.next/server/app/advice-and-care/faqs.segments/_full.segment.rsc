f:["$","link","0",{"rel":"stylesheet","href":"/_next/static/chunks/101urug~nzqva.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]
11:["$","p",null,{"children":"We will introduce you to your caregiver before your first visit so you can start to get to know each other."}]
12:["$","div",null,{"className":"space-y-4","children":["$","p",null,{"children":"At Naptec we believe that the best care is relationship-led and will ensure that you or your loved one will have a small group of caregivers that have been introduced to you. This ensures consistency and continuity in care being provided by a dedicated team of familiar people."}]}]
13:["$","div",null,{"className":"space-y-4","children":[["$","p",null,{"children":"At Naptec we have specially trained caregivers to support you and your loved ones in the best possible way. Our training approach to dementia care focuses on delivering the very best care and support to those living with dementia, helping keep them happy and healthy at home."}],["$","p",null,{"className":"mt-4","children":["$","$L7",null,{"href":"/what-we-do/dementia-and-alzheimers","className":"text-sm font-medium text-[#3B2A8F] underline underline-offset-4 transition-colors hover:text-[#2d1f6d]","children":"Discover more"}]}]]}]
14:["$","div",null,{"className":"space-y-4","children":[["$","p",null,{"children":"There are a number of options when it comes to paying for care, and we have pulled together the relevant information for each part of the UK depending on the options that are available."}],["$","p",null,{"className":"mt-4","children":["$","$L7",null,{"href":"/advice-and-care/cost-of-care","className":"text-sm font-medium text-[#3B2A8F] underline underline-offset-4 transition-colors hover:text-[#2d1f6d]","children":"Discover more"}]}]]}]
15:["$","div",null,{"className":"space-y-4","children":[["$","p",null,{"children":"We use a digital care management system to schedule your calls and allocate them to your familiar caregivers. Caregivers use the digital system to log into and out of calls so we know that they have arrived on time and completed your call."}],["$","p",null,{"children":"Digital care planning is available along with an app which your representatives can access to see visit records and reassure themselves that care is being delivered in accordance with the care plan. Medication records are also available digitally which enable us to manage your medication safely."}]]}]
16:["$","div",null,{"className":"space-y-4","children":["$","p",null,{"children":"We will regularly review your service to ensure we are able to offer additional support as required, and your dedicated team of caregivers can also alert us to any changes in your condition. If at any time you feel your needs are changing, please talk to us about amending your service."}]}]
17:["$","div",null,{"className":"space-y-4","children":["$","p",null,{"children":"Our team of expert caregivers will give your loved one the highest standard of care possible: from keeping them up-to-date with medication to keeping them company and helping with their daily life, so they can live the way they are most comfortable with."}]}]
18:["$","div",null,{"className":"space-y-4","children":["$","p",null,{"children":"Of course. We are there to help your family live happily, and that includes keeping in contact. Whether it is keeping an ear out for the phone, or putting the kettle on when you visit, our team are there to help."}]}]
19:["$","div",null,{"className":"space-y-4","children":["$","p",null,{"children":"We work with you to create a plan that works best for you and your loved one's needs. We know care needs can change, so our plans are always flexible too."}]}]
1a:["$","div",null,{"className":"space-y-4","children":["$","p",null,{"children":"A personal alarm is something you can consider, along with plenty of other options to help reduce the anxiety associated with living with dementia. All of our caregivers are trained to help provide support with dementia, and we can suggest more specialist help if required."}]}]
